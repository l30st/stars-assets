id = "bazaar_panel_triple"
priority = 1

type = "BazaarPanel"
subtype = "Single"

sc_file_source = "ClientFile"
sc_file = "sc/shop.sc"
export_name = "offer_panel_big"

copy_configs=[ "bazaar_panel_shared_configs" ]

move = [
	{ binding="small_item_grid", offset=[-30, -50] },
]

[custom]
int.small_item_count = 6
int.large_item_count = 3
float.width = 730.0
vector2.small_item_step = [105,105]

[bindings]
large_1 = { path="item_1_ph" }
large_2 = { path="item_2_ph" }
large_3 = { path="item_3_ph" }
