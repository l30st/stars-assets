id = "bazaar_panel_double"
priority = 1

type = "BazaarPanel"
subtype = "Single"

sc_file_source = "ClientFile"
sc_file = "sc/shop.sc"
export_name = "offer_panel_medium"

copy_configs=[ "bazaar_panel_shared_configs" ]

[custom]
int.small_item_count = 3
int.large_item_count = 2
int.small_items_columns = 1
float.width = 540.0
float.small_item_row_nudge = -12.0
vector2.small_item_scale = [0.9, 0.9]
vector2.small_item_step = [110, 110]
vector2.small_item_offset = [22.0, -40.0]

[bindings]
large_1 = { path="item_1_ph" }
large_2 = { path="item_2_ph" }
